            cfg.Open = not cfg.Open
            els.Window.Instance.Position = UDim2.new(0, els.Swatch.Instance.AbsolutePosition.X, 0, els.Swatch.Instance.AbsolutePosition.Y+(cfg.Open and 64 or 74))
            els.Window:Tween({Position = UDim2.new(0, els.Swatch.Instance.AbsolutePosition.X, 0, els.Swatch.Instance.AbsolutePosition.Y+(cfg.Open and 74 or 64))})
            els.Window:FadeAll(cfg.Open, cfg)
        end

        cfg.UpdateFromMouse = function()
            local mp  = kUI.UserInputService:GetMouseLocation()
            local off = Vector2.new(mp.X, mp.Y-_inset)
            if dragSat then
                s = math.clamp((off-els.SatLayer.Instance.AbsolutePosition).X/els.SatLayer.Instance.AbsoluteSize.X, 0, 1)
                v = 1-math.clamp((off-els.SatLayer.Instance.AbsolutePosition).Y/els.SatLayer.Instance.AbsoluteSize.Y, 0, 1)
            elseif dragHue then
                h = math.clamp((off-els.Hue.Instance.AbsolutePosition).Y/els.Hue.Instance.AbsoluteSize.Y, 0, 1)
            elseif dragAlpha then
                a = math.clamp((off-els.Alpha.Instance.AbsolutePosition).X/els.Alpha.Instance.AbsoluteSize.X, 0, 1)
            end
            cfg.Apply()
        end

        cfg.Apply = function(color, alpha)
            if type(color) == "boolean" then return end
            if color then h,s,v = color:ToHSV() end
            if alpha then a = alpha end
            local ti   = TweenInfo.new(lib.dragSpeed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0)
            local col3 = Color3.fromHSV(h,s,v)
            els.Swatch.Instance.BackgroundColor3 = col3
            els.SV.Instance.BackgroundColor3 = Color3.fromHSV(h,1,1)
            els.AlphaGrad.Instance.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color3.fromHSV(h,1,1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(h,1,1)),
            }
            els.SVCursor:Tween({Position = UDim2.new(s,0,1-v,0)}, ti)
            els.AlphaCursor:Tween({Position = UDim2.new(a,0,0.5,0)}, ti)
            els.HueCursor:Tween({Position = UDim2.new(0.5,0,h,0)}, ti)
            if not els.RGBInput.Focused then
                els.RGBInput.els.Textbox.Instance.Text = ("%s, %s, %s, %s"):format(
                    lib:Snap(col3.R*255), lib:Snap(col3.G*255), lib:Snap(col3.B*255), lib:Snap(1-a,0.01)
                )
            end
            flags[cfg.Flag] = {Color = col3, Transparency = a}
            cfg.Callback(col3, a)
        end

        els.Swatch:OnClick(cfg.SetOpen)
        els.Window:OutsideClick(cfg)

        local function stopDrag() dragSat=false; dragHue=false; dragAlpha=false end
        els.Alpha:OnDrag(cfg.UpdateFromMouse, function(d) if d then dragAlpha=true else stopDrag() end end)
        els.Hue:OnDrag(cfg.UpdateFromMouse, function(d) if d then dragHue=true else stopDrag() end end)
        els.SatLayer:OnDrag(cfg.UpdateFromMouse, function(d) if d then dragSat=true else stopDrag() end end)

        cfg.Apply(cfg.Color, cfg.Alpha)
        cfgFlags[cfg.Flag] = cfg.Apply

        if self.UpdateSection then
            self.UpdateSection(els.Root.Instance or self.els.Root.Instance)
        end

        return setmetatable(cfg, lib)
    end

