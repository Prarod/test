            function cfg:SetEnabled(b) cfg.On = b end
            cfg:ChangeKey(cfg.Key); cfg:ChangeName(cfg.Text)
            self.hotkeys[cfg.Index] = cfg
            return setmetatable(cfg, lib)
        end

        lib.TickHotkeys = function(self)
            yOff = 0; bigX = 0
            for _, obj in self.hotkeys do
                obj.Fade = lib:Lerp(obj.Fade, obj.On and 255 or 0, 0.02)
                local inst = obj.els.Row.Instance
                local alpha = 1-(obj.Fade/255)
                inst.Position = UDim2.new(0,-(inst.AbsoluteSize.X-(inst.AbsoluteSize.X*(obj.Fade/255))),0,yOff)
                obj:SetKeypickerTransparency(alpha)
                if obj.On and bigX < inst.AbsoluteSize.X then bigX = math.max(bigX, inst.AbsoluteSize.X) end
                yOff += inst.AbsoluteSize.Y*(obj.Fade/255)
                self.Window.els.KeybindScroll.Instance.Size = UDim2.new(0,200,0,yOff+22)
            end
        end

        lib.SetKeypickerTransparency = function(self, n)
            self.els.Row.Instance.GroupTransparency = n
        end
    end

    -- // Toast notifications
    do
        lib.hud = lib:New("ScreenGui", {
            Parent = kUI.CoreGui; Name="\0"; Enabled=true;
            IgnoreGuiInset=true; ZIndexBehavior=Enum.ZIndexBehavior.Sibling;
            DisplayOrder=1000001;
        })

        local yOff, bigX = 0, 0

        lib.Toast = function(self, data)
            data = data or {}
            local cfg = setmetatable({
                Text     = data.Title or data.Name or data.Text or "kumka cheat";
                Duration = data.Lifetime or 5;
                els      = {};
                On       = true;
                Fade     = 2;
                Tick     = tick();
                Index    = #self.toasts+1;
            }, lib)
            local els = cfg.els; do
                els.Box = lib:New("CanvasGroup", { GroupTransparency=1; Parent=lib.hud.Instance; Position=UDim2.new(0,30,0,60); BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.XY; BackgroundColor3=palette.Palette.Bg })
                els.Bar = lib:New("Frame", { Parent=els.Box.Instance; Position=UDim2.new(0,-3,1,-1); Size=UDim2.new(0,0,0,3); BorderSizePixel=0; BackgroundColor3=palette.Palette.Accent }):Paint("Accent","BackgroundColor3")
                els.Icon = lib:New("ImageLabel", { ImageColor3=palette.Palette.Accent; Parent=els.Box.Instance; AnchorPoint=Vector2.new(0,0.5); Image="rbxassetid://82851477751652"; BackgroundTransparency=1; Position=UDim2.new(0,5,0.5,-2); Size=UDim2.new(0,16,0,16); BorderSizePixel=0 }):Paint("Accent","ImageColor3")
                els.Title = lib:New("TextLabel", { TextColor3=Color3.fromRGB(235,235,240); Text=cfg.Text; Parent=els.Box.Instance; BackgroundTransparency=1; BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.XY })
                lib:New("UIPadding", { PaddingTop=UDim.new(0,4); PaddingBottom=UDim.new(0,8); Parent=els.Title.Instance; PaddingRight=UDim.new(0,5); PaddingLeft=UDim.new(0,24) })
                lib:New("UIPadding", { PaddingTop=UDim.new(0,2); PaddingBottom=UDim.new(0,2); Parent=els.Box.Instance; PaddingRight=UDim.new(0,2); PaddingLeft=UDim.new(0,2) })
                lib:New("UICorner", { Parent=els.Box.Instance })
            end
            self.toasts.list[cfg.Index] = cfg
            els.Bar:Tween({Size=UDim2.new(1,4,0,3)}, TweenInfo.new(cfg.Duration, lib.animStyle, lib.animDir, 0, false, 0))
            task.delay(cfg.Duration+1, function()
                els.Box.Instance:Destroy()
                self.toasts.list[cfg.Index] = nil
            end)
            return cfg
        end

        lib.TickToasts = function(self)
            yOff = 0; bigX = 0
            local t = tick()
            for _, obj in self.toasts.list do
                obj.Fade = obj.Fade or 2
                obj.Fade = lib:Lerp(obj.Fade, obj.On and 255 or 0, 0.02)
                if t-obj.Tick >= obj.Duration then obj.On = false end
                local inst  = obj.els.Box.Instance
                local alpha = 1-(obj.Fade/255)
                inst.Position = UDim2.new(0,30,0,80) + UDim2.new(0,-(inst.AbsoluteSize.X-(inst.AbsoluteSize.X*(obj.Fade/255))),0,yOff)
                obj:SetTransparency(alpha)
                if obj.On and bigX < inst.AbsoluteSize.X then bigX = math.max(bigX, inst.AbsoluteSize.X) end
                yOff += (inst.AbsoluteSize.Y+6)*(obj.Fade/255)
            end
        end

        lib.SetTransparency = function(self, n)
            self.els.Box.Instance.GroupTransparency = n
        end

        lib:Toast({ Text = "kumka cheat loaded" })
    end

    -- // Mod list
    do
        local yOff, bigX = 0, 0

        lib.AddMod = function(self, data)
            data = data or {}
            local cfg = {
                Text  = data.Title or data.Name or data.Text or "Mod";
                els   = {};
                On    = true;
                Fade  = 2;
                Tick  = tick();
                Index = #self.modsList+1;
            }
            local els = cfg.els; do
                els.Row = lib:New("CanvasGroup", { Parent=self.Window.els.ModScroll.Instance; BackgroundTransparency=1; Size=UDim2.new(1,0,0,25); BorderSizePixel=0; BackgroundColor3=Color3.new(1,1,1) })
                els.Name = lib:New("TextLabel", { Parent=els.Row.Instance; TextColor3=palette.Palette.Dim; Text=""; AutomaticSize=Enum.AutomaticSize.XY; AnchorPoint=Vector2.new(0,0); Position=UDim2.new(0,0,0,0); BackgroundTransparency=1; TextXAlignment=Enum.TextXAlignment.Left; BorderSizePixel=0; ZIndex=2 })
                lib:New("UIPadding", { PaddingTop=UDim.new(0,4); PaddingBottom=UDim.new(0,6); Parent=els.Name.Instance; PaddingRight=UDim.new(0,5); PaddingLeft=UDim.new(0,7) })
            end
            function cfg:ChangeName(n) els.Name.Instance.Text = tostring(n) end
            function cfg:Remove()
                cfg.On = false
                task.delay(1, function() els.Row.Instance:Destroy() end)
            end
            cfg:ChangeName(cfg.Text)
            self.modsList[cfg.Index] = cfg
            return setmetatable(cfg, lib)
        end

        lib.TickMods = function(self)
            yOff = 0; bigX = 0
            for _, obj in self.modsList do
                obj.Fade = lib:Lerp(obj.Fade, obj.On and 255 or 0, 0.02)
                local inst  = obj.els.Row.Instance
                local alpha = 1-(obj.Fade/255)
                inst.Position = UDim2.new(0,-(inst.AbsoluteSize.X-(inst.AbsoluteSize.X*(obj.Fade/255))),0,yOff)
                obj:SetModTransparency(alpha)
                if obj.On and bigX < inst.AbsoluteSize.X then bigX = math.max(bigX, inst.AbsoluteSize.X) end
                yOff += inst.AbsoluteSize.Y*(obj.Fade/255)
                self.Window.els.ModScroll.Instance.Size = UDim2.new(0,200,0,yOff+22)
            end
        end

        lib.SetModTransparency = function(self, n)
            self.els.Row.Instance.GroupTransparency = n
        end
    end

    lib:Hook(kUI.RunService.Heartbeat, function()
        if not (lib.TickToasts and lib.TickMods and lib.TickHotkeys) then return end
        lib:TickToasts()
        lib:TickHotkeys()
        lib:TickMods()
    end)
end

return getgenv().kumka
