    lib.AddSlider = function(self, data)
        data = data or {}
        local cfg = {
            Text      = data.Text or "Slider";
            Suffix    = data.Suffix or "";
            Flag      = data.Flag or data.Name or "Slider";
            Callback  = data.Callback or function() end;
            Min       = data.Min or 0;
            Max       = data.Max or 100;
            Step      = data.Decimal or data.Rounding or 1;
            Value     = data.Default or 10;
            Dragging  = false;
            els       = {};
        }
        local els = cfg.els; do
            els.Root = lib:New("TextButton", { Parent=self.els.Elements.Instance; BackgroundTransparency=1; Size=UDim2.new(1,0,0,33); BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.Y })
            els.Title = lib:New("TextLabel", { FontFace=palette.Palette.Font; TextColor3=Color3.fromRGB(235,235,240); Text=cfg.Text; Parent=els.Root.Instance; AutomaticSize=Enum.AutomaticSize.XY; BackgroundTransparency=1; Position=UDim2.new(0,-1,0,0); BorderSizePixel=0; ZIndex=2 })
            els.Val = lib:New("TextLabel", { FontFace=palette.Palette.Font; TextColor3=Color3.fromRGB(235,235,240); Text="0"; Parent=els.Root.Instance; AnchorPoint=Vector2.new(1,0); AutomaticSize=Enum.AutomaticSize.XY; BackgroundTransparency=1; Position=UDim2.new(1,0,0,0); BorderSizePixel=0; ZIndex=2 })
            els.Fill = lib:New("Frame", { Parent=els.Root.Instance; Size=UDim2.new(0.5,-2,0,5); Position=UDim2.new(0,1,0,27); ZIndex=2; BorderSizePixel=0; BackgroundColor3=palette.Palette.Accent }):Paint("Accent","BackgroundColor3")
            lib:New("UIGradient", { Parent=els.Fill.Instance; Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,0.82),NumberSequenceKeypoint.new(1,0)} })
            lib:New("UIStroke", { Color=palette.Palette.Accent; Parent=els.Fill.Instance }):Paint("Accent","Color")
            lib:New("UICorner", { Parent=els.Fill.Instance; CornerRadius=UDim.new(1,0) })
            els.Knob = lib:New("Frame", { AnchorPoint=Vector2.new(0.5,0.5); Parent=els.Fill.Instance; Position=UDim2.new(1,0,0.5,0); Size=UDim2.new(0,7,0,7); ZIndex=2; BorderSizePixel=0; BackgroundColor3=Color3.fromRGB(246,245,254) })
            lib:New("UIStroke", { Color=palette.Palette.Txt; Parent=els.Knob.Instance }):Paint("Txt","Color")
            lib:New("UICorner", { Parent=els.Knob.Instance; CornerRadius=UDim.new(1,8) })
            els.Track = lib:New("Frame", { Parent=els.Root.Instance; Position=UDim2.new(0,0,0,26); Size=UDim2.new(1,1,0,7); BorderSizePixel=0; BackgroundColor3=palette.Palette.ElBg }):Paint("ElBg","BackgroundColor3")
            lib:New("UICorner", { Parent=els.Track.Instance; CornerRadius=UDim.new(1,0) })
        end

        cfg.Set = function(val)
            cfg.Value = math.clamp(lib:Snap(val, cfg.Step), cfg.Min, cfg.Max)
            els.Val.Instance.Text = tostring(cfg.Value)..cfg.Suffix
            els.Fill:Tween({Size=UDim2.new((cfg.Value-cfg.Min)/(cfg.Max-cfg.Min),-2,0,5)}, TweenInfo.new(lib.dragSpeed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0))
            flags[cfg.Flag] = cfg.Value
            cfg.Callback(flags[cfg.Flag])
        end

        cfg.Set(cfg.Value)
        els.Track:OnDrag(function(i)
            local pct = (i.Position.X - els.Track.Instance.AbsolutePosition.X) / els.Track.Instance.AbsoluteSize.X
            cfg.Set(((cfg.Max-cfg.Min)*pct)+cfg.Min)
        end)
        self.UpdateSection(els.Root.Instance)
        cfgFlags[cfg.Flag] = cfg.Set
        return setmetatable(cfg, lib)
    end

