            els.Knob = lib:New("Frame", {
                AnchorPoint=Vector2.new(0,0.5); Parent=els.Track.Instance;
                Position=UDim2.new(0,2,0.5,0); Size=UDim2.new(0,12,0,12);
                BorderSizePixel=0; BackgroundColor3=Color3.fromRGB(56,56,56);
            })
            lib:New("UICorner", { Parent=els.Knob.Instance; CornerRadius=UDim.new(1,0) })
        end

