    lib.AddKeyPicker = function(self, data)
        data = data or {}
        local cfg = {
            Text       = data.Text or data.Name or data.Title or "Keybind";
            Flag       = data.Flag or data.Text or data.Name or data.Title or "Flag";
            Callback   = data.Callback or function() end;
            ShowInList = data.ShowInList ~= false;
            Key        = data.Key or data.Default or nil;
            Mode       = data.Mode or "Toggle";
            Active     = data.Active or false;
            Open       = false;
            busy       = false;
            Binding    = nil;
            els        = {};
            Debounce   = false;
        }

        flags[cfg.Flag] = { Mode=cfg.Mode; Key=cfg.Key; Active=cfg.Active; active=cfg.Active }

        local els = cfg.els; do
            els.Root = lib:New("Frame", { Parent=self.els.Elements.Instance; BackgroundTransparency=1; Size=UDim2.new(1,0,0,16); BorderSizePixel=0 })
            els.Title = lib:New("TextLabel", { FontFace=palette.Palette.Font; TextColor3=Color3.fromRGB(235,235,240); Text=cfg.Text; Parent=els.Root.Instance; AnchorPoint=Vector2.new(0,0.5); AutomaticSize=Enum.AutomaticSize.XY; BackgroundTransparency=1; Position=UDim2.new(0,-1,0.5,0); BorderSizePixel=0; ZIndex=2 })
            els.BindHolder = lib:New("Frame", { Parent=els.Root.Instance; Position=UDim2.new(1,0,0,0); Size=UDim2.new(0,0,1,0); BorderSizePixel=0 })
            lib:New("UIListLayout", { FillDirection=Enum.FillDirection.Horizontal; HorizontalAlignment=Enum.HorizontalAlignment.Right; Parent=els.BindHolder.Instance; Padding=UDim.new(0,13); SortOrder=Enum.SortOrder.LayoutOrder })
            els.KeyBox = lib:New("Frame", {
                AnchorPoint=Vector2.new(1,0); Parent=els.BindHolder.Instance;
                Position=UDim2.new(1,0,0,0); Size=UDim2.new(0,34,0,16);
                BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.X;
                BackgroundColor3=palette.Palette.Base;
            }):Paint("Base","BackgroundColor3")
            lib:New("UIStroke", { Color=palette.Palette.Seam; Parent=els.KeyBox.Instance }):Paint("Seam","Color")
            lib:New("UIPadding", { Parent=els.KeyBox.Instance; PaddingRight=UDim.new(0,8); PaddingLeft=UDim.new(0,8) })
            lib:New("UICorner", { Parent=els.KeyBox.Instance; CornerRadius=UDim.new(0,5) })
            els.KeyLabel = lib:New("TextLabel", { FontFace=palette.Palette.Font; TextColor3=Color3.fromRGB(235,235,240); Text="NONE"; Parent=els.KeyBox.Instance; AnchorPoint=Vector2.new(0,0.5); AutomaticSize=Enum.AutomaticSize.XY; BackgroundTransparency=1; Position=UDim2.new(0,-1,0.5,0); BorderSizePixel=0; ZIndex=2 })

            local settingsSection = lib:AddSection({Text="Settings"})
            els.ModeDD = settingsSection:AddDropdown({Text="Mode"; Flag=cfg.Flag.."_MODE"; Options={"Toggle","Hold","Always"}; Callback=function(opt)
                if cfg.Debounce then return end
                if cfg.Set then cfg.Set(opt) end
            end})
            els.SettingsSec = settingsSection.els.Section
            els.SettingsSec.Instance.Parent = lib.root.Instance
            els.SettingsSec.Instance.Visible = false
            els.SettingsSec:Reparent(lib.layer.Instance)
        end

        local kbEl = lib:AddHotKey({Key=cfg.Key or "NONE"; Name=cfg.Text})

        cfg.SetMode = function(mode)
            cfg.Mode = mode
            if mode == "Always" then cfg.Set(true)
            elseif mode == "Hold" then cfg.Set(false) end
            flags[cfg.Flag].Mode = mode
        end

        cfg.Set = function(input)
            if type(input) == "boolean" then
                cfg.Active = input
                if cfg.Mode == "Always" then cfg.Active = true end
            elseif tostring(input):find("Enum") then
                input = input.Name == "Escape" and "NONE" or input
                cfg.Key = input or "NONE"
            elseif table.find({"Toggle","Hold","Always"}, input) then
                if input == "Always" then cfg.Active = true end
                cfg.Mode = input; cfg.SetMode(cfg.Mode)
            elseif type(input) == "table" then
                input.Key = type(input.Key)=="string" and input.Key~="NONE" and lib:EnumStr(input.Key) or input.Key
                input.Key = input.Key==Enum.KeyCode.Escape and "NONE" or input.Key
                cfg.Key = input.Key or "NONE"
                if input.Active then cfg.Active = input.Active end
                cfg.SetMode(input.Mode)
            end
            cfg.Callback(cfg.Active)
            local raw = (tostring(cfg.Key)~="Enums" and (_binds[cfg.Key] or tostring(cfg.Key):gsub("Enum.","")) or nil)
            local display = raw and tostring(raw):gsub("KeyCode.",""):gsub("UserInputType.","") or ""
            els.KeyLabel.Instance.Text = ("Key: %s"):format(display)
            cfg.Debounce = true; els.ModeDD.Set(cfg.Mode); cfg.Debounce = false
            kbEl:ChangeKey(display or "NONE")
            kbEl:SetEnabled(cfg.Active)
            flags[cfg.Flag] = { Mode=cfg.Mode; Key=cfg.Key; Active=cfg.Active; active=cfg.Active }
        end

        cfg.NewKey = function()
            task.wait()
            els.KeyLabel.Instance.Text = "..."
            cfg.Binding = lib:Hook(kUI.UserInputService.InputBegan, function(kc, ge)
                if ge then return end
                cfg.Set(kc.KeyCode~=Enum.KeyCode.Unknown and kc.KeyCode or kc.UserInputType)
                cfg.Binding.Connection:Disconnect(); cfg.Binding = nil
            end)
        end

        cfg.SetVisible = function(bool)
            if cfg.busy then return end
            task.wait()
            local pos = els.KeyBox.Instance.AbsolutePosition
            els.SettingsSec:FadeAll(bool, cfg)
            els.SettingsSec:Tween({Position=UDim2.fromOffset(pos.X+1, pos.Y+80)})
        end

        els.KeyBox:OnClick(cfg.NewKey)
        els.ModeDD.els.Menu:OnClick(function()
            task.spawn(function() cfg.busy=true; task.wait(); cfg.busy=false end)
        end)
        els.SettingsSec:OutsideClick(cfg)

        lib:Hook(els.KeyBox.Instance.InputBegan, function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton2 then
                cfg.Open = not cfg.Open; cfg.SetVisible(cfg.Open)
            end
        end)

        lib:Hook(kUI.UserInputService.InputBegan, function(i, ge)
            if ge then return end
            local k = i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode or i.UserInputType
            if k==cfg.Key or tostring(k)==cfg.Key then
                if cfg.Mode=="Toggle" then cfg.Active=not cfg.Active; cfg.Set(cfg.Active)
                elseif cfg.Mode=="Hold" then cfg.Set(true) end
            end
        end)

        lib:Hook(kUI.UserInputService.InputEnded, function(i, ge)
            if ge then return end
            local k = i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode or i.UserInputType
            if k==cfg.Key or tostring(k)==cfg.Key then
                if cfg.Mode=="Hold" then cfg.Set(false) end
            end
        end)

        cfg.Set({Mode=cfg.Mode; Active=cfg.Active; Key=cfg.Key})
        cfgFlags[cfg.Flag] = cfg.Set
        self.UpdateSection(els.Root.Instance)
        return setmetatable(cfg, lib)
    end

