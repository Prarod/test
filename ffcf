getgenv().kumka = {
    Folder      = "kumka",
    SubFolders  = { "/fonts", "/configs", "/themes", "/sounds" },

    flags       = {};
    cfgFlags    = {};
    connections = {};
    threads     = {};
    blurs       = {};
    toasts      = { list = {} };
    hotkeys     = {};
    modsList    = {};

    activeEl    = {};

    animStyle   = Enum.EasingStyle.Quint;
    animDir     = Enum.EasingDirection.InOut;
    animSpeed   = 0.35;
    dragSpeed   = 0.04;
    busy        = false;
}; do
    local lib = getgenv().kumka
    lib.__index = lib

    for _, p in lib.SubFolders do
        makefolder(lib.Folder .. p)
    end

    if not isfile(lib.Folder .. "/autoload.txt") then
        writefile(lib.Folder .. "/autoload.txt", "")
    end

    local flags    = lib.flags
    local cfgFlags = lib.cfgFlags
    local toasts   = lib.toasts

    local palette = {
        Palette = {
            ["Accent"]          = Color3.fromRGB(220, 100, 40),
            ["ElBg"]            = Color3.fromRGB(22, 22, 26),
            ["SecBg"]           = Color3.fromRGB(16, 16, 20),
            ["ElOutline"]       = Color3.fromRGB(32, 32, 38),
            ["Seam"]            = Color3.fromRGB(26, 26, 32),
            ["Base"]            = Color3.fromRGB(25, 25, 28),
            ["TabBg"]           = Color3.fromRGB(20, 20, 25),
            ["Dim"]             = Color3.fromRGB(140, 140, 150),
            ["Txt"]             = Color3.fromRGB(235, 235, 240),
            ["Bg"]              = Color3.fromRGB(13, 13, 16),
            ["Font"]            = Font.new("rbxassetid://12187365364", Enum.FontWeight.SemiBold, Enum.FontStyle.Normal)
        };
        _reg = {};
    }; do
        for col, _ in palette.Palette do
            if col == "Font" then continue end
            palette._reg[col] = {
                BackgroundColor3 = {};
                TextColor3       = {};
                ImageColor3      = {};
                ScrollBarImageColor3 = {};
                Color            = {};
            }
        end

        lib.Paint = function(self, slot, prop)
            table.insert(palette._reg[slot][prop], self.Instance)
            return self
        end

        lib.Repaint = function(self, slot, col)
            for prop, objs in palette._reg[slot] do
                for _, obj in objs do
                    if (prop == "Color" or prop == "Transparency") and not (obj:IsA("UIStroke") or obj:IsA("UIGradient")) then
                        continue
                    end
                    if obj[prop] == palette.Palette[slot] then
                        obj[prop] = col
                    end
                end
            end
            palette.Palette[slot] = col
        end

        lib.GetPalette = function(self)
            local out = {}
            for k, v in palette.Palette do
                if k == "Font" then continue end
                out[k] = { Transparency = 1, Color = v:ToHex() }
            end
            return kUI.HttpService:JSONEncode(out)
        end

        lib.SaveTheme = function(self, name)
            writefile(("%s/themes/%s.cfg"):format(lib.Folder, name), self:GetPalette())
        end

        lib.DeleteTheme = function(self, name)
            local p = ("%s/themes/%s.cfg"):format(lib.Folder, name)
            if isfile(p) then delfile(p) end
        end

        lib.RefreshThemeList = function(self)
            local list = {}
            for _, f in listfiles(lib.Folder .. "/themes") do
                list[#list+1] = f:gsub(lib.Folder.."/themes\\",""):gsub(".cfg",""):gsub(lib.Folder.."\\themes\\","")
            end
            self.RefreshOptions(list)
        end
    end

    lib.TransProps = function(self, obj)
        if obj:IsA("Frame") then
            return {"BackgroundTransparency"}
        elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then
            return {"TextTransparency","BackgroundTransparency"}
        elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
            return {"BackgroundTransparency","ImageTransparency"}
        elseif obj:IsA("ScrollingFrame") then
            return {"BackgroundTransparency","ScrollBarImageTransparency"}
        elseif obj:IsA("TextBox") then
            return {"TextTransparency","BackgroundTransparency"}
        elseif obj:IsA("UIStroke") then
            return {"Transparency"}
        elseif obj:IsA("BasePart") then
            return {"Transparency"}
        end
        return nil
    end

    lib.Tween = function(self, props, info, obj)
        local inst = self.Instance or obj
        local tw = kUI.TweenService:Create(
            inst,
            info or TweenInfo.new(lib.animSpeed, lib.animStyle, Enum.EasingDirection.InOut, 0, false, 0),
            props
        )
        tw:Play()
        return tw
    end

    lib.FadeProp = function(self, obj, prop, show)
        if not (prop and obj) then return end
        local orig = obj[prop]
        obj[prop] = show and 1 or orig
        local anim = lib:Tween({[prop] = show and orig or 1}, nil, obj)
        lib:Hook(anim.Completed, function()
            if not show then obj[prop] = orig end
        end)
        return anim
    end

    lib.FadeAll = function(self, visible, state)
        state = state or {busy = false}
        if state.busy then return end
        local inst = self.Instance
        state.busy = true
        if visible then inst.Visible = true end
        local children = inst:GetDescendants()
        table.insert(children, inst)
        if self.Blur then table.insert(children, self.Blur) end
        local last
        for _, obj in children do
            local props = lib:TransProps(obj)
            if not props then continue end
            if type(props) == "table" then
                for _, p in props do last = lib:FadeProp(obj, p, visible) end
            else
                last = lib:FadeProp(obj, props, visible)
            end
        end
        lib:Hook(last.Completed, function()
            state.busy = false
            inst.Visible = visible
        end)
    end

    lib.MakeResizable = function(self)
        local inst = self.Instance
        local btn = lib:New("TextButton", {
            Position = UDim2.new(1,-10,1,-10);
            Size = UDim2.new(0,10,0,10);
            BorderSizePixel = 0;
            Parent = inst;
            BackgroundTransparency = 1;
            Text = ""
        })
        local resizing, szStart, posStart, baseSize = false, nil, nil, inst.Size
        btn.Instance.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true; posStart = i.Position; szStart = inst.Size
            end
        end)
        btn.Instance.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
        end)
        lib:Hook(kUI.UserInputService.InputChanged, function(i)
            if resizing and i.UserInputType == Enum.UserInputType.MouseMovement then
                self:Tween({
                    Size = UDim2.new(
                        szStart.X.Scale,
                        math.clamp(szStart.X.Offset+(i.Position.X-posStart.X), baseSize.X.Offset, _cam.ViewportSize.X),
                        szStart.Y.Scale,
                        math.clamp(szStart.Y.Offset+(i.Position.Y-posStart.Y), baseSize.Y.Offset, _cam.ViewportSize.Y)
                    )
                }, TweenInfo.new(lib.dragSpeed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0))
            end
        end)
    end

    lib.IsHovered = function(self)
        local ap = self.Instance.AbsolutePosition
        local as = self.Instance.AbsoluteSize
        return _mouse.X >= ap.X and _mouse.X <= ap.X+as.X
           and _mouse.Y >= ap.Y and _mouse.Y <= ap.Y+as.Y
    end

    lib.MakeDraggable = function(self)
        local inst = self.Instance
        local dragging, startPos, startMouse = false, nil, nil
        inst.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true; startMouse = i.Position; startPos = inst.Position
            end
        end)
        inst.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
        lib:Hook(kUI.UserInputService.InputChanged, function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                self:Tween({
                    Position = UDim2.new(0, startPos.X.Offset+(i.Position.X-startMouse.X), 0, startPos.Y.Offset+(i.Position.Y-startMouse.Y))
                }, TweenInfo.new(lib.dragSpeed, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, 0, false, 0))
            end
        end)
        return self
    end

    lib.HexEncode = function(self, c)
        return ("#%02X%02X%02X"):format(math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
    end

    lib.HexDecode = function(self, hex)
        hex = hex:gsub("#","")
        return Color3.new(tonumber(hex:sub(1,2),16)/255, tonumber(hex:sub(3,4),16)/255, tonumber(hex:sub(5,6),16)/255)
    end

    lib.SplitRGB = function(self, str)
        local vals = {}
        for v in str:gmatch("[^,]+") do table.insert(vals, tonumber(v)) end
        if #vals == 4 then return unpack(vals) end
    end

    lib.EnumStr = function(self, e)
        local parts = {}
        for p in tostring(e):gmatch("[%w_]+") do table.insert(parts, p) end
        local t = tostring(e)
        for i = 2, #parts do t = t[parts[i]] end
        return t
    end

    lib.Lerp = function(self, a, b, t)
        t = t or 1/8
        return a*(1-t)+b*t
    end

    lib.Snap = function(self, n, step)
        local m = 1/(step or 1)
        return math.floor(n*m+0.5)/m
    end

    lib.RefreshConfigList = function(self)
        local list = {}
        for _, f in listfiles(lib.Folder.."/configs") do
            list[#list+1] = f:gsub(lib.Folder.."/configs\\",""):gsub(".cfg",""):gsub(lib.Folder.."\\configs\\","")
        end
        self.RefreshOptions(list)
    end

    lib.Thread = function(self, fn)
        local t = coroutine.create(fn)
        coroutine.wrap(function() coroutine.resume(t) end)()
        table.insert(self.threads, t)
        return t
    end

    lib.Safe = function(self, fn, ...)
        local ok, err = pcall(fn, ...)
        if not ok then warn(err) end
        return ok
    end

    lib.Hook = function(self, sig, cb)
        local info = { Event = sig, Callback = cb }
        lib:Thread(function()
            info.Connection = sig:Connect(cb)
        end)
        table.insert(self.connections, info)
        return info
    end

    lib.OnClick = function(self, cb)
        return lib:Hook(self.Instance.InputBegan, function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                cb()
            end
        end)
    end

    lib.OnHover = function(self, enter, leave)
        leave = leave or function() end
        lib:Hook(self.Instance.MouseEnter, enter)
        lib:Hook(self.Instance.MouseLeave, leave)
    end

    lib.OnDrag = function(self, onMove, onState)
        local dragging = false
        onState = onState or function() end
        self.Instance.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true; onState(true)
            end
        end)
        lib:Hook(kUI.UserInputService.InputEnded, function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false; onState(false)
            end
        end)
        lib:Hook(kUI.UserInputService.InputChanged, function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
                onMove(i)
            end
        end)
    end

    lib.Reparent = function(self, parent)
        parent = parent or self.Instance.Parent
        lib:Hook(self.Instance:GetPropertyChangedSignal("Visible"), function()
            self.Instance.Parent = self.Instance.Visible and parent or lib.overlay.Instance
        end)
    end

    lib.OutsideClick = function(self, state)
        return lib:Hook(kUI.UserInputService.InputBegan, function(i)
            if not self.Instance.Visible then return end
            if not (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then return end
            if not self:IsHovered() then state.SetVisible(false) end
        end)
    end

    lib.Kill = function(self)
        self.Connection:Disconnect()
    end

    lib.New = function(self, cls, opts)
        local info = { Instance = Instance.new(cls), Properties = opts, Blur = nil }
        local inst  = info.Instance
        for k, v in opts do inst[k] = v end
        if cls == "TextButton" then
            inst.AutoButtonColor = false
            inst.Text = ""
        end
        if cls == "TextLabel" or cls == "TextBox" then
            inst.FontFace = Font.new("rbxassetid://12187365364", Enum.FontWeight.SemiBold, Enum.FontStyle.Normal)
            inst.TextSize = 15
        end
        inst.Name = "\0"
        return setmetatable(info, lib)
    end

    lib.Destroy = function(self)
        repeat task.wait() until #self.toasts == 0
        for _, v in self.connections do
            if v.Connection then v.Connection:Disconnect() end
        end
        for _, v in self.threads do coroutine.close(v) end
        for _, item in {self.root, self.overlay, self.Blur, self.layer, self.hud} do
            if item then item.Instance:Destroy(); item = nil end
        end
        kumka = nil
        getgenv().kumka = nil
    end

    lib.CalcRayPos = function(self, pos, norm, orig, dir)
        local v = orig - pos
        local num = norm.x*v.x + norm.y*v.y + norm.z*v.z
        local den = norm.x*dir.x + norm.y*dir.y + norm.z*dir.z
        return orig + (-num/den)*dir
    end

    lib.root = lib:New("ScreenGui", {
        Parent = kUI.CoreGui; Name = "\0"; Enabled = true;
        ZIndexBehavior = Enum.ZIndexBehavior.Global;
        IgnoreGuiInset = true; DisplayOrder = 100;
    })

    lib.overlay = lib:New("ScreenGui", {
        Parent = kUI.CoreGui; Name = "\0"; Enabled = false;
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling;
        IgnoreGuiInset = true;
    })

    lib.layer = lib:New("ScreenGui", {
        Parent = kUI.CoreGui; Name = "\0"; Enabled = true;
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling;
        IgnoreGuiInset = true; DisplayOrder = 101;
    })

    -- // Config
    lib.GetConfig = function(self)
        local out = {}
        for k, v in flags do
            if type(v) == "table" and v.Key then
                out[k] = {Active = v.Active, Mode = v.Mode, Key = tostring(v.Key)}
            elseif type(v) == "table" and v.Transparency and v.Color then
                out[k] = {Transparency = v.Transparency, Color = v.Color:ToHex()}
            else
                out[k] = v
            end
        end
        return kUI.HttpService:JSONEncode(out)
    end

    lib.LoadConfig = function(self, json)
        local cfg = kUI.HttpService:JSONDecode(json)
        for k, v in cfg do
            local fn = cfgFlags[k]
            if k == "ignore" then continue end
            if fn then
                if type(v) == "table" and v.Transparency and v.Color then
                    fn(Color3.fromHex(v.Color), v.Transparency)
                else
                    fn(v)
                end
            end
        end
    end

    lib.DeleteConfig = function(self, name)
        local p = ("%s/configs/%s.cfg"):format(lib.Folder, name)
        if isfile(p) then delfile(p) end
    end

    lib.SaveConfig = function(self, name)
        writefile(("%s/configs/%s.cfg"):format(lib.Folder, name), self:GetConfig())
    end

    lib.AutoLoad = function(self)
        self.Window.busy = true
        local name = readfile(lib.Folder.."/autoload.txt")
        if name ~= "" then
            for i = 1, 2 do
                self:LoadConfig(readfile(("%s/configs/%s.cfg"):format(lib.Folder, name)))
            end
        end
        self.Window.busy = false
    end

