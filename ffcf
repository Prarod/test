                BorderSizePixel = 0;
                AutomaticSize = Enum.AutomaticSize.Y;
            })
            lib:New("UIPadding", { PaddingBottom=UDim.new(0,8); Parent=els.Elements.Instance })
            lib:New("UIListLayout", { Parent=els.Elements.Instance; Padding=UDim.new(0,13); SortOrder=Enum.SortOrder.LayoutOrder })
            lib:New("UICorner", { Parent=els.Section.Instance; CornerRadius=UDim.new(0,6) })
            lib:New("UIStroke", { Color=palette.Palette.Seam; Parent=els.Section.Instance }):Paint("Seam","Color")

