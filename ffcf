            }):Paint("ElBg","BackgroundColor3")
            els.HeaderFill1 = lib:New("Frame", {
                AnchorPoint = Vector2.new(0,1);
                Parent = els.Header.Instance;
                Position = UDim2.new(0,0,1,0);
                Size = UDim2.new(1,0,0,6);
                BorderSizePixel = 0;
                BackgroundColor3 = palette.Palette.ElBg;
            }):Paint("ElBg","BackgroundColor3")
            els.HeaderFill2 = lib:New("Frame", {
                Parent = els.Header.Instance;
                Position = UDim2.new(0,0,1,-1);
                Size = UDim2.new(1,0,0,1);
                BorderSizePixel = 0;
                BackgroundColor3 = palette.Palette.TabBg;
            }):Paint("TabBg","BackgroundColor3")
            lib:New("UICorner", { Parent=els.Header.Instance; CornerRadius=UDim.new(0,6) })

            els.Chevron = lib:New("ImageLabel", {
                Parent = els.Header.Instance;
                Size = UDim2.new(0,9,0,6);
                AnchorPoint = Vector2.new(1,0.5);
                Image = "rbxassetid://75133155165707";
                BackgroundTransparency = 1;
                Position = UDim2.new(1,-11,0.5,0);
                Rotation = 0;
                BorderSizePixel = 0;
                BackgroundColor3 = palette.Palette.Base;
            }):Paint("Base","BackgroundColor3")
        end

        cfg.Collapse = function(bool)
            if cfg.busy then return end
            cfg.Collapsed = bool
            if bool then
                els.Section:Tween({Size = UDim2.new(scaleX,offX,0,35)})
                els.HeaderFill1:Tween({BackgroundTransparency=1})
                els.HeaderFill2:Tween({BackgroundTransparency=1})
                els.Chevron:Tween({Rotation=180})
                els.Elements:Tween({Position=UDim2.new(0,12,0,23)})
                els.Elements:FadeAll(false, cfg)
            else
                els.Section:Tween({Size = UDim2.new(scaleX,offX,0,cfg.cachedH+36)})
                els.HeaderFill1:Tween({BackgroundTransparency=0})
                els.HeaderFill2:Tween({BackgroundTransparency=0})
                els.Chevron:Tween({Rotation=0})
                els.Elements:Tween({Position=UDim2.new(0,12,0,43)})
                els.Elements:FadeAll(true, cfg)
            end
