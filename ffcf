        els.AccentWatch.Instance:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
            if cfg.Enabled then
                els.TrackStroke:Tween({Color=palette.Palette.Accent})
                els.Track:Tween({BackgroundColor3=palette.Palette.Accent})
            end
        end)

        cfgFlags[cfg.Flag] = cfg.Set
        cfg.Set(cfg.Enabled)
        self.UpdateSection(els.Root.Instance)
        return setmetatable(cfg, lib)
    end

