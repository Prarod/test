            opt.Btn = lib:New("Frame", { Parent=els.Menu.Instance; BackgroundTransparency=1; Size=UDim2.new(1,0,0,0); BorderSizePixel=0; AutomaticSize=Enum.AutomaticSize.XY; BackgroundColor3=palette.Palette.Accent }):Paint("Accent","BackgroundColor3")
            lib:New("UIGradient", { Parent=opt.Btn.Instance; Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,0.59),NumberSequenceKeypoint.new(1,0)} })
            lib:New("UICorner", { Parent=opt.Btn.Instance; CornerRadius=UDim.new(0,5) })
            opt.Text = lib:New("TextLabel", { FontFace=palette.Palette.Font; Parent=opt.Btn.Instance; TextColor3=palette.Palette.Dim; Text=text; AutomaticSize=Enum.AutomaticSize.XY; AnchorPoint=Vector2.new(0,0.5); Size=UDim2.new(0,0,1,0); BackgroundTransparency=1; Position=UDim2.new(0,8,0.5,-1); BorderSizePixel=0; ZIndex=2 }):Paint("Dim","TextColor3"):Paint("Txt","TextColor3")
            lib:New("UIPadding", { PaddingBottom=UDim.new(0,10); PaddingTop=UDim.new(0,10); Parent=opt.Btn.Instance })
            opt.Stroke = lib:New("UIStroke", { Color=palette.Palette.Accent; Transparency=1; Parent=opt.Btn.Instance }):Paint("Accent","Color")
            table.insert(cfg.optEls, opt)
            return opt
        end

        cfg.SetVisible = function()
            if cfg.busy then return end
            cfg.Open = not cfg.Open
            local sz  = els.Box.Instance.AbsoluteSize
            local pos = els.Box.Instance.AbsolutePosition
            els.Menu.Instance.Size = UDim2.fromOffset(sz.X+2, 0)
            if cfg.Open then
                els.Menu.Instance.Position = UDim2.fromOffset(pos.X, pos.Y+75)
                els.Menu:Tween({Position=UDim2.fromOffset(pos.X, pos.Y+85)})
            else
                els.Menu:Tween({Position=UDim2.fromOffset(pos.X, pos.Y+75)})
            end
            els.Menu:FadeAll(cfg.Open, cfg)
        end

        cfg.Set = function(val)
            local sel = {}
            local isTbl = type(val) == "table"
            for _, opt in cfg.optEls do
                local t = opt.Text.Instance.Text
                if t == val or (isTbl and table.find(val, t)) then
                    table.insert(sel, t); cfg.selected = sel
                    opt.Text:Tween({TextColor3=palette.Palette.Txt})
                    opt.Btn:Tween({BackgroundTransparency=0})
                    opt.Stroke:Tween({Transparency=0})
                else
                    opt.Text:Tween({TextColor3=palette.Palette.Dim})
                    opt.Btn:Tween({BackgroundTransparency=1})
                    opt.Stroke:Tween({Transparency=1})
                end
            end
            els.ValLabel.Instance.Text = isTbl and table.concat(sel,", ") or sel[1] or ""
            flags[cfg.Flag] = isTbl and sel or sel[1]
            cfg.Callback(flags[cfg.Flag])
        end

        cfg.RefreshOptions = function(opts)
            for _, o in cfg.optEls do o.Btn.Instance:Destroy() end
            cfg.optEls = {}
            for _, o in opts do
                local btn = cfg.RenderOption(o)
                btn.Btn:OnClick(function()
                    if cfg.Multi then
                        local idx = table.find(cfg.selected, btn.Text.Instance.Text)
                        if idx then table.remove(cfg.selected, idx) else table.insert(cfg.selected, btn.Text.Instance.Text) end
                        cfg.Set(cfg.selected)
                    else
                        cfg.Set(btn.Text.Instance.Text)
                    end
                end)
            end
        end

        els.Box:OnClick(cfg.SetVisible)
        els.Menu:Reparent(lib.layer.Instance)
        els.Menu:OutsideClick(cfg)
        cfg.RefreshOptions(cfg.Options)
        cfg.SetVisible()
        cfg.Set(cfg.Default)
        self.UpdateSection(els.Dropdown.Instance)
        return setmetatable(cfg, lib)
    end

