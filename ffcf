                            local r,g,b,al = lib:SplitRGB(txt)
                            if r and g and b and al then
                                cfg.Apply(Color3.fromRGB(r,g,b), 1-al)
                            else
                                cfg.Apply(Color3.fromHSV(h,s,v), 1-al)
                            end
                        end
                    end
                })
