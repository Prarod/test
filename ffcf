                els.TrackStroke:Tween({Color=palette.Palette.Accent})
                els.Track:Tween({BackgroundColor3=palette.Palette.Accent})
                els.Label:Tween({TextColor3=palette.Palette.Txt})
            else
                els.Track:Tween({BackgroundColor3=palette.Palette.Seam})
                els.Knob:Tween({AnchorPoint=Vector2.new(0,0.5), Position=UDim2.new(0,2,0.5,0), BackgroundColor3=Color3.fromRGB(56,56,56)})
                els.TrackStroke:Tween({Color=palette.Palette.Seam})
                els.Label:Tween({TextColor3=palette.Palette.Dim})
            end
            flags[cfg.Flag] = bool
            cfg.Callback(bool)
