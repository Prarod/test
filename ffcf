            if self.TabInfo == cfg then
                els.TabTitle:Tween({TextColor3 = palette.Palette.Accent})
                els.TabIcon:Tween({ImageColor3 = palette.Palette.Accent})
            end
        end)

        if not self.TabInfo then cfg.Open() end

        return unpack(cfg.Sections)
    end

